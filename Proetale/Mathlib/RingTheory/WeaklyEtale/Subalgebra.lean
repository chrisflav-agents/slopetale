import Proetale.Mathlib.RingTheory.WeaklyEtale.FieldExtension
import Mathlib.RingTheory.Ideal.Pure
import Mathlib.RingTheory.Kaehler.Basic
import Mathlib.RingTheory.EssentialFiniteness

/-!
# Weakly √©tale subalgebras of fields

This file formalises the field-to-field specialisation of Stacks
[092K](https://stacks.math.columbia.edu/tag/092K): if `K ‚Üí L` is a weakly √©tale
extension of fields and `a ‚àà L`, then the `K`-subalgebra `K[a] = Algebra.adjoin K {a}`
is again weakly √©tale over `K`.

The bivariate corollary closes the transcendental case of Stacks 092P (the consumer
`Algebra.WeaklyEtale.isAlgebraic_of_isField_aux` in `FieldExtension.lean`): once
`K ‚Üí K[a]` is weakly √©tale and `a` is transcendental, `K[a] ‚äó_K K[a] ‚âÖ K[X, Y]` is
a domain whose multiplication kernel is the principal ideal `(X ‚àí Y)`, which is
neither `‚ä•` nor `‚ä§`, contradicting the idempotency forced by formal √©taleness.

## Main results

* `Algebra.WeaklyEtale.adjoin_singleton` ‚Äî
  `K ‚Üí Algebra.adjoin K {a}` is weakly √©tale when `K ‚Üí L` is and `a ‚àà L`.

## Proof strategy (Stacks 092K, field-to-field case)

Write `A := Algebra.adjoin K {a}`. Recall `Algebra.WeaklyEtale K A` decomposes into:

1. **Flatness `K ‚Üí A`**: automatic because `K` is a field; every `K`-module is free,
   hence flat.
2. **Flatness of `Œº_A : A ‚äó_K A ‚Üí A`**: since `Œº_A` is surjective with finitely
   generated kernel (`KaehlerDifferential.ideal K A` is FG by `EssFiniteType`),
   `RingHom.Flat Œº_A` is equivalent to `(ker Œº_A).Pure`, which by
   `Ideal.Pure.of_isIdempotentElem` reduces to `IsIdempotentElem (ker Œº_A)`.

The idempotency in `A ‚äó_K A` is the substantive Stacks 092K piece. It is inherited
from the absolutely flat overring `L ‚äó_K L` along the `K`-flat injection
`A ‚äó_K A ‚Ü™ L ‚äó_K L`. iter-021 lands the infrastructure file and the auxiliary
lemmas; the full descent argument remains as a typed `sorry` (its precise strategy
is documented in the proof body).
-/

universe u

open scoped TensorProduct
open Algebra

namespace Algebra.WeaklyEtale

variable (K L : Type u) [Field K] [Field L] [Algebra K L]

section AdjoinSingleton

variable (a : L)

/-- The kernel `KaehlerDifferential.ideal K A` of the multiplication map
`A ‚äó_K A ‚Üí A` is finitely generated when `A = Algebra.adjoin K {a}`, because `A`
is essentially of finite type over `K` (generated by the single element `a`). -/
private lemma kaehler_ideal_fg_adjoin :
    (KaehlerDifferential.ideal K
      (Algebra.adjoin K ({a} : Set L))).FG := by
  haveI : Algebra.FiniteType K (Algebra.adjoin K ({a} : Set L)) :=
    Algebra.FiniteType.adjoin_of_finite (Set.finite_singleton a)
  haveI : Algebra.EssFiniteType K (Algebra.adjoin K ({a} : Set L)) :=
    Algebra.EssFiniteType.of_finiteType K _
  exact KaehlerDifferential.ideal_fg K _

/-- The inclusion `A ‚äó_K A ‚Üí L ‚äó_K L` (where `A = Algebra.adjoin K {a}`) is
injective: `K`-flatness of `L` and `A` is automatic since `K` is a field, so the
tensor product of the inclusion `A ‚Ü™ L` with itself is injective. -/
private lemma adjoinTensorIncl_injective :
    Function.Injective
      (Algebra.TensorProduct.map
        (Algebra.adjoin K ({a} : Set L)).val
        (Algebra.adjoin K ({a} : Set L)).val :
          _ ‚Üí‚Çê[K] L ‚äó[K] L) := by
  have hinj : Function.Injective
      ((Algebra.adjoin K ({a} : Set L)).val : _ ‚Üí L) := Subtype.val_injective
  exact TensorProduct.map_injective_of_flat_flat _ _ hinj hinj

/-- For `A := Algebra.adjoin K {a}` inside `L`, the kernel of the multiplication
map `Œº_A : A ‚äó_K A ‚Üí A` is the principal ideal generated by the diagonal
`Œ¥ := 1 ‚äó a - a ‚äó 1`. The "‚äá" inclusion (containment) is `Œº_A Œ¥ = 0`. The "‚äÜ"
direction uses that every element of `A` is built from `a` via K-algebra
operations (`Algebra.adjoin_induction`); each diagonal `1 ‚äó b - b ‚äó 1` reduces
to a multiple of `Œ¥` by telescoping (mem case), additivity, and the
multiplicative split
`1‚äó(xy) - xy‚äó1 = (1‚äóx)(1‚äóy - y‚äó1) + (1‚äóx - x‚äó1)(y‚äó1)`. -/
private lemma kaehler_ideal_adjoin_singleton_eq_span :
    letI A' : Subalgebra K L := Algebra.adjoin K ({a} : Set L)
    letI aA : A' := ‚ü®a, Algebra.self_mem_adjoin_singleton K a‚ü©
    KaehlerDifferential.ideal K A' =
      Ideal.span ({(1 : A') ‚äó‚Çú[K] aA - aA ‚äó‚Çú[K] (1 : A')} :
        Set (A' ‚äó[K] A')) := by
  set A' : Subalgebra K L := Algebra.adjoin K ({a} : Set L)
  set aA : A' := ‚ü®a, Algebra.self_mem_adjoin_singleton K a‚ü©
  set Œ¥ : A' ‚äó[K] A' := (1 : A') ‚äó‚Çú[K] aA - aA ‚äó‚Çú[K] (1 : A')
  refine le_antisymm ?_ ?_
  ¬∑ rw [‚Üê KaehlerDifferential.span_range_eq_ideal]
    rw [Ideal.span_le]
    rintro _ ‚ü®b, rfl‚ü©
    obtain ‚ü®b', hb'‚ü© := b
    suffices h : ‚àÄ (y : L) (hy : y ‚àà Algebra.adjoin K ({a} : Set L)),
        ((1 : A') ‚äó‚Çú[K] (‚ü®y, hy‚ü© : A') -
          (‚ü®y, hy‚ü© : A') ‚äó‚Çú[K] (1 : A')) ‚àà Ideal.span ({Œ¥} : Set (A' ‚äó[K] A')) from
      h b' hb'
    intro y hy
    induction hy using Algebra.adjoin_induction with
    | mem x hx =>
      rw [Set.mem_singleton_iff] at hx
      subst hx
      exact Ideal.subset_span (Set.mem_singleton _)
    | algebraMap r =>
      have h0 : (1 : A') ‚äó‚Çú[K] (‚ü®algebraMap K L r,
          Subalgebra.algebraMap_mem _ _‚ü© : A') -
          (‚ü®algebraMap K L r,
            Subalgebra.algebraMap_mem _ _‚ü© : A') ‚äó‚Çú[K] (1 : A') = 0 := by
        have hval : (‚ü®algebraMap K L r,
            Subalgebra.algebraMap_mem _ _‚ü© : A') = algebraMap K A' r := rfl
        rw [hval, Algebra.algebraMap_eq_smul_one,
          TensorProduct.tmul_smul, TensorProduct.smul_tmul', sub_self]
      rw [h0]
      exact Ideal.zero_mem _
    | add x y hx hy IHx IHy =>
      have hsum : (‚ü®x + y, add_mem hx hy‚ü© : A') =
          (‚ü®x, hx‚ü© : A') + (‚ü®y, hy‚ü© : A') := rfl
      have heq : (1 : A') ‚äó‚Çú[K] (‚ü®x + y, add_mem hx hy‚ü© : A') -
          (‚ü®x + y, add_mem hx hy‚ü© : A') ‚äó‚Çú[K] (1 : A') =
          ((1 : A') ‚äó‚Çú[K] (‚ü®x, hx‚ü© : A') - (‚ü®x, hx‚ü© : A') ‚äó‚Çú[K] (1 : A')) +
          ((1 : A') ‚äó‚Çú[K] (‚ü®y, hy‚ü© : A') - (‚ü®y, hy‚ü© : A') ‚äó‚Çú[K] (1 : A')) := by
        rw [hsum, TensorProduct.tmul_add, TensorProduct.add_tmul]
        abel
      rw [heq]
      exact Ideal.add_mem _ IHx IHy
    | mul x y hx hy IHx IHy =>
      have hmul : (‚ü®x * y, mul_mem hx hy‚ü© : A') =
          (‚ü®x, hx‚ü© : A') * (‚ü®y, hy‚ü© : A') := rfl
      have h1 : ((1 : A') ‚äó‚Çú[K] ((‚ü®x, hx‚ü© : A') * (‚ü®y, hy‚ü© : A')) :
            A' ‚äó[K] A') =
          ((1 : A') ‚äó‚Çú[K] (‚ü®x, hx‚ü© : A')) *
            ((1 : A') ‚äó‚Çú[K] (‚ü®y, hy‚ü© : A')) := by
        rw [Algebra.TensorProduct.tmul_mul_tmul, mul_one]
      have h2 : (((‚ü®x, hx‚ü© : A') * (‚ü®y, hy‚ü© : A')) ‚äó‚Çú[K] (1 : A') :
            A' ‚äó[K] A') =
          ((‚ü®x, hx‚ü© : A') ‚äó‚Çú[K] (1 : A')) *
            ((‚ü®y, hy‚ü© : A') ‚äó‚Çú[K] (1 : A')) := by
        rw [Algebra.TensorProduct.tmul_mul_tmul, mul_one]
      have heq : (1 : A') ‚äó‚Çú[K] (‚ü®x * y, mul_mem hx hy‚ü© : A') -
          (‚ü®x * y, mul_mem hx hy‚ü© : A') ‚äó‚Çú[K] (1 : A') =
          ((1 : A') ‚äó‚Çú[K] (‚ü®x, hx‚ü© : A')) *
            ((1 : A') ‚äó‚Çú[K] (‚ü®y, hy‚ü© : A') -
              (‚ü®y, hy‚ü© : A') ‚äó‚Çú[K] (1 : A')) +
          ((1 : A') ‚äó‚Çú[K] (‚ü®x, hx‚ü© : A') -
            (‚ü®x, hx‚ü© : A') ‚äó‚Çú[K] (1 : A')) *
            ((‚ü®y, hy‚ü© : A') ‚äó‚Çú[K] (1 : A')) := by
        rw [hmul, h1, h2]
        ring
      rw [heq]
      exact Ideal.add_mem _
        (Ideal.mul_mem_left _ _ IHy)
        (Ideal.mul_mem_right _ _ IHx)
  ¬∑ rw [Ideal.span_le, Set.singleton_subset_iff]
    show Œ¥ ‚àà KaehlerDifferential.ideal K A'
    rw [KaehlerDifferential.ideal, RingHom.mem_ker]
    show Algebra.TensorProduct.lmul' (R := K) (S := A')
        ((1 : A') ‚äó‚Çú[K] aA - aA ‚äó‚Çú[K] (1 : A')) = 0
    rw [map_sub, Algebra.TensorProduct.lmul'_apply_tmul,
      Algebra.TensorProduct.lmul'_apply_tmul, one_mul, mul_one, sub_self]

/-- If the kernel of the multiplication map `Œº : S ‚äó[R] S ‚Üí S` is a pure ideal,
then `Œº : S ‚äó[R] S ‚Üí+* S` is flat. This is the standard step that converts
purity of `KaehlerDifferential.ideal R S` into flatness of `lmul'`. -/
private lemma flat_lmul'_of_pure_ker {R S : Type*} [CommRing R] [CommRing S]
    [Algebra R S] (hpure : (KaehlerDifferential.ideal R S).Pure) :
    (Algebra.TensorProduct.lmul' (R := R) (S := S)).toRingHom.Flat := by
  -- Unfold to `Module.Flat (S‚äóS) S` under the `lmul'.toAlgebra` structure.
  rw [RingHom.Flat]
  letI : Algebra (S ‚äó[R] S) S :=
    (Algebra.TensorProduct.lmul' (R := R) (S := S)).toRingHom.toAlgebra
  -- Under this algebra structure, `algebraMap (S‚äóS) S = lmul'`.
  have h_alg : algebraMap (S ‚äó[R] S) S =
      (Algebra.TensorProduct.lmul' (R := R) (S := S)).toRingHom := rfl
  -- `algebraMap` is (S‚äóS)-linear (it's the algebraMap!), and surjective.
  have h_sur : Function.Surjective (Algebra.linearMap (S ‚äó[R] S) S) := by
    intro x; exact ‚ü®x ‚äó‚Çú[R] 1, by simp [Algebra.linearMap, h_alg]‚ü©
  -- `LinearMap.ker (Algebra.linearMap _ _)` is the underlying submodule of
  -- `KaehlerDifferential.ideal R S`.
  have h_ker_eq : LinearMap.ker (Algebra.linearMap (S ‚äó[R] S) S) =
      (KaehlerDifferential.ideal R S).restrictScalars (S ‚äó[R] S) := by
    ext x
    simp [Algebra.linearMap, KaehlerDifferential.ideal, RingHom.mem_ker, h_alg]
  -- `LinearMap.quotKerEquivOfSurjective` gives a (S‚äóS)-linear iso
  -- `(S‚äóS) ‚ß∏ LinearMap.ker(linearMap) ‚âÉ‚Çó[S‚äóS] S`.
  have hsur_iso :
      ((S ‚äó[R] S) ‚ß∏ LinearMap.ker (Algebra.linearMap (S ‚äó[R] S) S))
        ‚âÉ‚Çó[S ‚äó[R] S] S :=
    LinearMap.quotKerEquivOfSurjective _ h_sur
  -- The underlying submodule of `KaehlerDifferential.ideal R S` (after
  -- `restrictScalars`) equals the LinearMap kernel, so the two quotients
  -- are the same.
  -- `hpure : Module.Flat (S‚äóS) ((S‚äóS) ‚ß∏ KaehlerDifferential.ideal R S)`.
  -- That `Pure` is `Module.Flat (S‚äóS) ((S‚äóS) ‚ß∏ I)` where the quotient is
  -- the ideal quotient. We need to transport to the submodule quotient.
  -- For ideals, `(R‚ß∏I)` as a Ring with R-module structure coincides with
  -- the submodule quotient, so the two are definitionally equal.
  have h_flat_quot : Module.Flat (S ‚äó[R] S)
      ((S ‚äó[R] S) ‚ß∏ LinearMap.ker (Algebra.linearMap (S ‚äó[R] S) S)) := by
    rw [h_ker_eq]
    -- Now want `Module.Flat (S‚äóS) ((S‚äóS) ‚ß∏ ((KaehlerDifferential.ideal R S).restrictScalars _))`.
    -- This is the same as `Pure (KaehlerDifferential.ideal R S)` up to identification.
    exact hpure
  exact Module.Flat.of_linearEquiv hsur_iso.symm

/-- **Stacks [092K], field-to-field specialisation.**

If `K ‚Üí L` is a weakly √©tale extension of fields and `a ‚àà L`, then the
`K`-subalgebra `K[a] = Algebra.adjoin K {a}` is weakly √©tale over `K`.

This is the key descent lemma used to close the transcendental case of Stacks 092P
(`Algebra.WeaklyEtale.isSeparable_algebraic_of_isField`): once `K ‚Üí K[a]` is
weakly √©tale, idempotency of `ker Œº_{K[a]}` together with `K[a] ‚äó_K K[a]` being
a domain (in the transcendental case) forces a contradiction.

**iter-021 status**: signature landed; auxiliary FG and injectivity lemmas proved
(see `kaehler_ideal_fg_adjoin`, `adjoinTensorIncl_injective`). The substantive
Stacks 092K descent of idempotency from `ker Œº_L` (idempotent in the absolutely
flat ring `L ‚äó_K L`) down to `ker Œº_{K[a]}` inside the K-flat subring
`K[a] ‚äó_K K[a] ‚Ü™ L ‚äó_K L` remains as a typed `sorry`. The argument routes through
the explicit description of `ker Œº_{K[a]}` as the ideal generated by the
diagonals `{1 ‚äó b ‚àí b ‚äó 1 : b ‚àà A}` and uses that each such generator,
multiplied by the idempotent `e ‚àà L ‚äó_K L` exhibiting idempotency in the
overring, lands back in `A ‚äó_K A` (the precise iter-020 gap). -/
theorem adjoin_singleton [Algebra.WeaklyEtale K L] :
    Algebra.WeaklyEtale K (Algebra.adjoin K ({a} : Set L)) := by
  -- Set `A := Algebra.adjoin K {a}` and split the `WeaklyEtale` structure into
  -- (1) `Module.Flat K A` and (2) `RingHom.Flat (lmul' K (S := A))`.
  set A : Subalgebra K L := Algebra.adjoin K ({a} : Set L) with _hA_def
  refine ‚ü®?_, ?_‚ü©
  ¬∑ -- (1) Flatness of `K ‚Üí A`: automatic because `K` is a field.
    exact inferInstance
  ¬∑ -- (2) Flatness of `Œº_A : A ‚äó_K A ‚Üí A`. Reduces (via the principal-ideal
    -- characterisation of pure ideals) to idempotency of
    -- `KaehlerDifferential.ideal K A`; this idempotency is the substantive
    -- Stacks 092K descent step, deferred to iter-022.
    --
    -- Ingredients in scope (mechanical):
    -- * `kaehler_ideal_fg_adjoin K L a` ‚Äî FG of the kernel.
    -- * `adjoinTensorIncl_injective K L a` ‚Äî the K-flat injection
    --   `A ‚äó_K A ‚Ü™ L ‚äó_K L` is injective.
    -- * `Ideal.Pure.of_isIdempotentElem` ‚Äî FG + idempotent ‚áí pure.
    -- * `Module.Flat.of_linearEquiv` ‚Äî transport flatness across
    --   `(A‚äóA)/(ker Œº) ‚âÉ A`.
    --
    -- The descent (the sole iter-022 obligation): given the K-flat injection
    -- `i : A ‚äó_K A ‚Ü™ L ‚äó_K L`, the idempotent generator `e ‚àà L ‚äó_K L` of
    -- `KaehlerDifferential.ideal K L` (Stacks 092K input ‚Äî `L ‚äó_K L`
    -- absolutely flat via `absolutelyFlat_tensor_self`) restricts to a
    -- self-multiplication map on `i (A ‚äó_K A)` that exhibits idempotency of
    -- `KaehlerDifferential.ideal K A` inside `A ‚äó_K A`.
    have hker_FG : (KaehlerDifferential.ideal K
        (Algebra.adjoin K ({a} : Set L))).FG :=
      kaehler_ideal_fg_adjoin K L a
    -- Substantive Stacks 092K descent step.
    have hker_idem : IsIdempotentElem (KaehlerDifferential.ideal K
        (Algebra.adjoin K ({a} : Set L))) := by
      -- The strategy (Stacks 092K diagonal-generators route):
      -- (i)  Get an idempotent generator `e ‚àà L ‚äó L` of `ker Œº_L` from absolute
      --      flatness of `L ‚äó_K L` (via `absolutelyFlat_tensor_self K L`).
      -- (ii) The K-flat injection `i : A‚äóA ‚Ü™ L‚äóL` (`adjoinTensorIncl_injective`)
      --      sends each diagonal `1‚äób - b‚äó1 ‚àà ker Œº_A` to `1‚äób - b‚äó1 ‚àà ker Œº_L`.
      -- (iii) Pull back the idempotency relation along `i` using injectivity.
      -- Steps (i) and (ii) are formalised explicitly below; the descent at
      -- step (iii) is the residual gap.
      classical
      haveI : Ring.AbsolutelyFlat (L ‚äó[K] L) := absolutelyFlat_tensor_self K L
      -- The kernel `ker Œº_L` is pure (since every ideal of an absolutely flat
      -- ring is pure).
      have hL_pure : (KaehlerDifferential.ideal K L).Pure :=
        Ring.AbsolutelyFlat.flat _
      -- Hence idempotent.
      have hL_idem : IsIdempotentElem (KaehlerDifferential.ideal K L) :=
        Ideal.isIdempotentElem_of_pure _
      -- Set up notation for the K-flat injection `i : A‚äóA ‚Ü™ L‚äóL`.
      let A' : Subalgebra K L := Algebra.adjoin K ({a} : Set L)
      let i : (A' ‚äó[K] A') ‚Üí‚Çê[K] L ‚äó[K] L :=
        Algebra.TensorProduct.map A'.val A'.val
      have hi_inj : Function.Injective i := adjoinTensorIncl_injective K L a
      -- `Œº_L ‚àò i = A'.val ‚àò Œº_A`: the multiplication map commutes with the
      -- inclusion of the subalgebra.
      have h_compat : ‚àÄ x : A' ‚äó[K] A',
          (Algebra.TensorProduct.lmul' (R := K) (S := L)) (i x) =
            A'.val ((Algebra.TensorProduct.lmul' (R := K) (S := A')) x) := by
        intro x
        induction x with
        | zero => simp
        | tmul s t => simp [i, Algebra.TensorProduct.map_tmul]
        | add x y hx hy => simp [map_add, hx, hy]
      -- `ker Œº_A` maps into `ker Œº_L` under `i`.
      have h_image_mem : ‚àÄ x ‚àà KaehlerDifferential.ideal K A',
          i x ‚àà KaehlerDifferential.ideal K L := by
        intro x hx
        rw [RingHom.mem_ker] at hx ‚ä¢
        simp [h_compat x, hx]
      -- **iter-024 principal-ideal route.** Since `A' = K[a]` is generated
      -- by the single element `a`, the kernel `ker Œº_A'` is the principal
      -- ideal generated by `Œ¥ := 1 ‚äó a - a ‚äó 1`. Then `Œ¥ ‚àà (Ideal.span {Œ¥})¬≤`
      -- reduces idempotency of the ideal to an element-level identity, and
      -- the L-side purity (`hL_pure`) combined with the K-flat projection
      -- `L‚äóL ‚Üí A'‚äóA'` provides the witness.
      let aA : A' := ‚ü®a, Algebra.self_mem_adjoin_singleton K a‚ü©
      let Œ¥ : A' ‚äó[K] A' := (1 : A') ‚äó‚Çú[K] aA - aA ‚äó‚Çú[K] (1 : A')
      -- Step (i): the kernel is principal, generated by Œ¥. (Helper lemma.)
      have hker_principal :
          KaehlerDifferential.ideal K A' = Ideal.span {Œ¥} :=
        kaehler_ideal_adjoin_singleton_eq_span K L a
      -- Step (ii): Œ¥ ‚àà (Ideal.span {Œ¥})¬≤. This is the substantive descent
      -- obstacle: the L-side gives `Œ¥_L ‚àà (Ideal.span {Œ¥_L})¬≤ ‚äÜ L‚äóL` via
      -- absolute flatness (every element of an absolutely flat ring lies
      -- in its square), but the witness lives in `L‚äóL`, and projecting it
      -- to a witness in `A'‚äóA'` requires a K-linear retraction
      -- `r : L ‚Üí A'` of the inclusion `A' ‚Ü™ L`, lifted to `r‚äór : L‚äóL ‚Üí A'‚äóA'`.
      -- The K-linear complement of `A'` in `L` exists (every K-subspace
      -- splits), but turning this into an `A'‚äóA'`-module retraction (so
      -- that `(r‚äór)(Œ¥_L¬≤¬∑y_L) = Œ¥¬≤¬∑(r‚äór)(y_L)`) requires `r` itself to be
      -- `A'`-linear, which generally fails when `L` is not `A'`-free
      -- (e.g., `L = K(a)` and `A' = K[a]` with `a` transcendental).
      -- A correct route uses a *finer* projection that exploits that
      -- `Œ¥ ‚àà A'‚äóA'` to land cross-summand contributions in the complement.
      -- This residual gap is the iter-025 obligation.
      have hidem_principal : Œ¥ ‚àà (Ideal.span ({Œ¥} : Set (A' ‚äó[K] A'))) ^ 2 := by
        sorry
      -- Step (iii): conclude `IsIdempotentElem (KaehlerDifferential.ideal K A')`.
      rw [hker_principal]
      rw [IsIdempotentElem]
      rw [pow_two] at hidem_principal
      apply le_antisymm
      ¬∑ -- `span {Œ¥} * span {Œ¥} ‚â§ span {Œ¥}`.
        exact Ideal.mul_le_left
      ¬∑ -- `span {Œ¥} ‚â§ span {Œ¥} * span {Œ¥}` follows from `Œ¥ ‚àà span {Œ¥} * span {Œ¥}`.
        rw [Ideal.span_le, Set.singleton_subset_iff]
        exact hidem_principal
    have hker_pure : (KaehlerDifferential.ideal K
        (Algebra.adjoin K ({a} : Set L))).Pure :=
      Ideal.Pure.of_isIdempotentElem hker_FG hker_idem
    -- From `(ker Œº_A).Pure` deduce `RingHom.Flat (lmul' K (S := A))`.
    -- The factorisation `lmul' = e ‚àò q` where `q : A‚äóA ‚Üí (A‚äóA)‚ß∏ker` is the
    -- quotient map and `e : (A‚äóA)‚ß∏ker ‚âÉ A` is the first isomorphism gives
    -- `Flat (e ‚àò q) = Flat q .comp Flat e`. `Flat q` is purity of the
    -- kernel; `Flat e` follows from `e` being a ring isomorphism.
    exact flat_lmul'_of_pure_ker (R := K) (S := A) hker_pure

end AdjoinSingleton

end Algebra.WeaklyEtale
